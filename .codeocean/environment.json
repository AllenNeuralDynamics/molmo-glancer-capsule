{
	"version": 1,
	"base_image": "codeocean/pytorch:2.4.0-cuda12.4.0-mambaforge24.5.0-0-python3.12.4-ubuntu22.04",
	"post_install": true,
	"options": {
		"registry_host_arg": true,
		"git_ask_pass": true,
		"mount_secrets": true
	},
	"installers": {
		"apt": {
			"packages": [
				{
					"name": "gcc",
					"version": "4:11.2.0-1ubuntu1"
				},
				{
					"name": "libgl1-mesa-glx",
					"version": "23.0.4-0ubuntu1~22.04.1"
				},
				{
					"name": "libglib2.0-0",
					"version": "2.72.4-0ubuntu2.9"
				}
			],
			"install_software_properties_common": true
		},
		"pip3": {
			"packages": [
				{
					"name": "ai2-olmo-core",
					"version": "2.4.0"
				}
			],
			"options": {},
			"pre_install_options": {}
		},
		"vscode": {
			"packages": [
				{
					"name": "anthropic.claude-code"
				}
			],
			"version": "4.100.3"
		}
	}
}